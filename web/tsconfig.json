{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "esModuleInterop": true,
    "sourceMap": true,
    "outDir": "dist",
    "types": ["@webgpu/types"]
  },
  "include": ["src/**/*"]
}
